VITE_CURRENCY = "$"
VITE_SUPABASE_URL = ""
VITE_SUPABASE_ANON_KEY = ""
# Destination WhatsApp number for new orders. Country code (52) + area code (33) + number.
VITE_WHATSAPP_BUSINESS_NUMBER = "523330089383"
# Origin address used to calculate the delivery fee.
VITE_STORE_ADDRESS = "Cipriano Campos Alatorre 1283, Villas del Nilo, 44824 Guadalajara, Jalisco"
# Coordinates of the store as a "lat,lon" string. Optional; geocoded from VITE_STORE_ADDRESS
# automatically when this is blank.
VITE_STORE_COORDINATES = "20.6426,-103.2888"
# Optional but recommended for checkout. Enable Maps JavaScript API + Geocoding API
# in Google Cloud and restrict this public browser key by domain and API.
VITE_GOOGLE_MAPS_API_KEY = ""
# Free delivery radius in kilometres.
VITE_DELIVERY_FREE_KM = "2"
# Price (MXN) charged per kilometre beyond the free radius.
VITE_DELIVERY_PER_KM_MXN = "5.50"
# Orders at or above this subtotal get free delivery up to the configured distance cap.
VITE_DELIVERY_FREE_ORDER_MIN_MXN = "600"
# Maximum distance in kilometres covered by the free-delivery promo.
VITE_DELIVERY_FREE_ORDER_MAX_KM = "15"
# Price (MXN) per kilometre beyond the free-delivery promo distance cap.
VITE_DELIVERY_LONG_DISTANCE_PER_KM_MXN = "5.50"
# Development-only fallback when Supabase is not configured.
# Never use this as production security; VITE_ values are public in the browser.
VITE_ADMIN_PASSWORD = ""
VITE_SITE_URL = "https://amorae.mx"
